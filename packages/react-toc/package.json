{
  "name": "@hyunjinno/react-toc",
  "version": "2.0.2",
  "description": "A library that automatically generates a Table of Contents (TOC) from your headings with scroll tracking.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./heading": {
      "types": "./dist/heading.d.mts",
      "import": "./dist/heading.mjs",
      "require": "./dist/heading.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch ./src"
  },
  "keywords": [
    "react",
    "react-component",
    "toc",
    "table-of-contents",
    "ui"
  ],
  "author": "HyunJinNo",
  "homepage": "https://hyunjinno.github.io/react-toc",
  "repository": {
    "type": "git",
    "url": "https://github.com/HyunJinNo/react-toc"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@tsdown/css": "^0.21.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tsdown": "^0.21.3",
    "typescript": "^5.9.3"
  }
}
